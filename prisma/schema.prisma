// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===============================
// Tenants & Users 
// ===============================

enum SystemRole {
  USER
  SUPER_ADMIN
}
enum TenantRole {
  OWNER
  ADMIN
  STAFF
  MEMBER
}
enum TenantUserStatus {
  ACTIVE
  INACTIVE
}

// Añade relaciones en Tenant
model Tenant {
  id           String @id @default(cuid())
  name         String
  subdomain    String @unique
  address      String
  settings     Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt @default(now())
  users        TenantUser[]
  invitations  Invitation[]
  // Billing
  subscriptions Subscription[]
  invoices      Invoice[]
  payments      Payment[]

  @@map("tenants")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  emailVerified DateTime?
  image         String?
  systemRole    SystemRole @default(USER)
  tenantUsers   TenantUser[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt @default(now())
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model TenantUser {
  id String @id @default(cuid())
  
  userId String
  user User @relation(fields: [userId], references: [id])

  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id])

  roles TenantRole[] @default([])
  status TenantUserStatus @default(ACTIVE)

  @@unique([userId, tenantId])
}

model Invitation {
  id String @id @default(cuid())

  email String
  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id])
  role TenantRole

  expiresAt DateTime
  usedAt DateTime?
  @@map("invitations")
}

// ===============================
// Billing (Tenant ↔ Gymni)
// ===============================
enum BillingProvider { 
  MANUAL 
  LEMONSQUEEZY 
  PADDLE 
}
enum SubStatus { 
  active
  canceled
}
enum InvoiceStatus { 
  open 
  paid 
  void 
  uncollectible 
}
enum PaymentMethod { 
  CASH 
  TRANSFER 
  CARD 
  OTHER
}
enum BillingInterval { 
  MONTH
  YEAR
}

model Plan {
  id        String  @id @default(cuid())
  code      String  @unique          // "STARTER", "PRO", "SCALE"
  name      String
  limits    Json                    // { membersActiveMax: 400, ... }
  isActive  Boolean @default(true)
  prices    PlanPrice[]
  subscriptions Subscription[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
  @@map("plans")
}

model PlanPrice {
  id          String  @id @default(cuid())
  planId      String
  plan        Plan    @relation(fields: [planId], references: [id])
  interval    BillingInterval       // MONTH | YEAR
  amountCents Int
  currency    String                // "MXN" | "USD"
  providerVariantId String?
  validFrom   DateTime @default(now())
  validTo     DateTime?
  isActive    Boolean  @default(true)
  subscriptions Subscription[]
  @@map("plan_prices")
  @@index([planId, interval, currency])
}

model Subscription {
  id               String  @id @default(cuid())
  tenantId         String
  tenant           Tenant  @relation(fields: [tenantId], references: [id])
  planId           String
  plan             Plan    @relation(fields: [planId], references: [id])
  priceId          String
  price            PlanPrice @relation(fields: [priceId], references: [id])
  provider         BillingProvider @default(MANUAL)
  status           SubStatus       @default(active)
  billingInterval  BillingInterval
  currentPeriodEnd DateTime
  trialEnd         DateTime?
  canceledAt       DateTime?
  providerSubId    String? @unique
  invoices         Invoice[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt @default(now())
  @@map("subscriptions")
  @@index([tenantId, status])
}

model Invoice {
  id               String  @id @default(cuid())
  tenantId         String
  tenant           Tenant  @relation(fields: [tenantId], references: [id])
  subscriptionId   String
  subscription     Subscription @relation(fields: [subscriptionId], references: [id])
  amountCents      Int
  currency         String
  status           InvoiceStatus @default(open)
  issuedAt         DateTime @default(now())
  dueAt            DateTime?
  // snapshots
  planId           String
  priceId          String
  providerInvoiceId String? @unique
  payments         Payment[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt @default(now())
  @@map("invoices")
  @@index([tenantId, status])
}

model Payment {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id])
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  method      PaymentMethod
  amountCents Int
  paidAt      DateTime
  reference   String?
  receivedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())
  @@map("payments")
  @@index([tenantId, paidAt])
  @@unique([invoiceId, reference]) // evita doble captura por mismo folio
}

// ===============================
// Billing (Member ↔ Tenant)
// ===============================

model MembershipPlan {
  id String @id @default(cuid())
  tenantId String
  name String

}