generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===============================
// Tenants
// ===============================

model Tenant {
  id String @id @default(cuid())
  name String
  address String
  subdomain String @unique
  settings Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
  users TenantUser[]
  invitations Invitation[]

  @@map("tenants")
}

// ===============================
// Users
// ===============================

enum SystemRole {
  USER
  SUPER_ADMIN
}


model User {
  id String @id @default(cuid())
  email String @unique
  password String 
  name String
  systemRole SystemRole @default(USER)
  tenantUsers TenantUser[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
  @@map("users")
}

enum TenantRole {
  OWNER
  ADMIN
  STAFF
  MEMBER
}

enum TenantUserStatus {
  ACTIVE
  INACTIVE
}

model TenantUser {
  id String @id @default(cuid())
  
  userId String
  user User @relation(fields: [userId], references: [id])

  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id])

  role TenantRole
  status TenantUserStatus @default(ACTIVE)

  @@unique([userId, tenantId])
}

model Invitation {
  id String @id @default(cuid())

  email String
  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id])
  role TenantRole

  expiresAt DateTime
  usedAt DateTime?
  @@map("invitations")
}

